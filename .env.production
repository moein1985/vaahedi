# ─── Database (PostgreSQL — Docker internal) ──────────
DATABASE_URL=postgresql://vaahedi:vaahedi_prod_pass_2026@postgres:5432/vaahedi?schema=public

# ─── Redis (Docker internal) ──────────────────────────
REDIS_URL=redis://redis:6379

# ─── JWT ──────────────────────────────────────────────
JWT_ACCESS_SECRET=vhd_access_xK9mP2qR7wT4nJ6yB3cF8eA1dG5hL0s
JWT_REFRESH_SECRET=vhd_refresh_mQ2nR8tY5uI1oP4aS7dF0gH3jK6lZ9x
