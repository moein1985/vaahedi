{
  "name": "@repo/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "cd ../../packages/db && npm run db:generate",
    "db:migrate": "cd ../../packages/db && npm run db:migrate"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.2.0",
    "@repo/db": "*",
    "@repo/shared": "*",
    "@sentry/node": "^10.39.0",
    "@trpc/server": "11.0.0-rc.693",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.34.0",
    "fastify": "^5.3.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.3",
    "nodemailer": "^6.10.0",
    "openai": "^4.87.0",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.34.5",
    "superjson": "^2.2.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.17",
    "@types/sharp": "^0.31.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.0",
    "vitest": "^3.0.7"
  }
}
