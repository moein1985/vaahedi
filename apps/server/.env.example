# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=1.0

# App
APP_ENV=development
APP_PORT=4000
APP_URL=https://your-domain.ir
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/vaahedi"

# JWT
JWT_ACCESS_SECRET=your-access-secret
JWT_REFRESH_SECRET=your-refresh-secret

# Redis
REDIS_URL=redis://localhost:6379

# MinIO/S3
S3_ENDPOINT=http://localhost:9000
S3_USE_SSL=false
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=vaahedi-uploads

# AvalAI
AVALAI_API_KEY=
AVALAI_BASE_URL=https://api.avalapis.ir/v1
AVALAI_MODEL=gemini-3.1-flash-lite-preview

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=info
NODE_ENV=development
READINESS_TIMEOUT_MS=3000