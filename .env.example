# ─── Application ─────────────────────────────────────
NODE_ENV=development
APP_PORT=4000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# ─── Database (PostgreSQL) ────────────────────────────
DATABASE_URL=postgresql://vaahedi:vaahedi_pass@localhost:5432/vaahedi?schema=public
# In Docker network use: postgresql://vaahedi:vaahedi_pass@postgres:5432/vaahedi

# ─── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# In Docker network use: redis://redis:6379

# ─── JWT ─────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── OTP / SMS ───────────────────────────────────────
SMS_PROVIDER_API_KEY=
SMS_PROVIDER_URL=https://api.ippanel.com/v1
SMS_SENDER_NUMBER=

# ─── Email (SMTP) ────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.ir
SMTP_PASS=
EMAIL_FROM="Vaahedi <noreply@example.ir>"

# ─── MinIO / Object Storage ──────────────────────────
S3_ENDPOINT=http://localhost:9000
# In Docker network use: http://minio:9000
S3_ACCESS_KEY=vaahedi_minio
S3_SECRET_KEY=vaahedi_minio_secret
S3_BUCKET=vaahedi-uploads
S3_REGION=ir-thr-at1
S3_USE_SSL=false

# ─── Upload Limits ───────────────────────────────────
MAX_FILE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_DOC_TYPES=application/pdf,image/jpeg,image/png
ALLOWED_VIDEO_TYPES=video/mp4,video/webm

# ─── Rate Limiting ───────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── AI Chat (avalai.ir - فاز آینده) ─────────────────
AVALAI_API_KEY=
AVALAI_BASE_URL=https://api.avalai.ir/v1
AVALAI_MODEL=google/gemini-2.0-flash-exp

# ─── Monitoring ──────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info

# ─── MinIO internal (Docker only) ────────────────────
MINIO_ROOT_USER=vaahedi_minio
MINIO_ROOT_PASSWORD=vaahedi_minio_secret

# ─── PostgreSQL internal (Docker only) ───────────────
POSTGRES_DB=vaahedi
POSTGRES_USER=vaahedi
POSTGRES_PASSWORD=vaahedi_pass
